{
  "manifest_version": 2,
  "name": "Map Diff",
  "version": "1.1.0",
  "description": "Shows win rate differences per map on the Overwatch Hero Statistics page",
  "permissions": [
    "storage",
    "https://overwatch.blizzard.com/*"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://overwatch.blizzard.com/*/rates/*"],
      "js": ["browser-api.js", "defaults.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "applications": {
    "gecko": {
      "id": "mapdiff@firefox",
      "strict_min_version": "57.0"
    }
  }
}
